# ══════════════════════════════════════════════════════════════
# Docker Build Context Optimization
# ══════════════════════════════════════════════════════════════
# Excludes unnecessary files from Docker build context
# Benefits: Faster builds, smaller context, improved security
# ══════════════════════════════════════════════════════════════

# Dependencies (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (SECURITY: Never include in image)
.env
.env.*
!.env.example

# Git files
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentation
README.md
DEVOPS.md
*.md
docs/

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Testing
test/
tests/
*.test.js
*.spec.js
coverage/
.nyc_output/

# Build artifacts
dist/
build/
*.log

# Docker files (no need to copy into image)
Dockerfile*
docker-compose*.yml
.dockerignore

# OS files
Thumbs.db
.DS_Store

# Temporary files
tmp/
temp/
*.tmp